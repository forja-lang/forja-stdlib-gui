funcion bottom_sheet(hijo, visible: Texto) { retornar hijo }

# Hoja inferior modal (con overlay semitransparente)
funcion hoja_inferior_modal(hijo, visible: Texto) { retornar hijo }
funcion modal_sheet(hijo, visible: Texto) { retornar hijo }

# Hoja inferior expandida (ocupa ~90% de altura)
funcion hoja_inferior_grande(hijo, visible: Texto) { retornar hijo }
funcion expanded_sheet(hijo, visible: Texto) { retornar hijo }

