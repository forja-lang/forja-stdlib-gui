funcion pull_to_refresh(hijo, cb, refrescando: Texto) { retornar hijo }
funcion pulltorefresh(hijo, cb) { retornar hijo }
funcion tirar_recargar(hijo, cb) { retornar hijo }

# Swipe-to-dismiss: contenido que se puede descartar deslizando
# hijo: widget a envolver
