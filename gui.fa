# Módulo: gui
# Descripción: API gráfica nativa completa con Xilem (framework UI reactivo)
# Instalación: forja add gui && forja install
# Uso: importar "gui"
#
# NOTA: Este paquete solo funciona al transpilar a Rust con cargo.
#       La VM de Forja no renderiza ventanas nativas.
# Dependencia Rust: xilem = "0.4"

# ─── Layout ───

# Contenedor vertical (flex columna)
funcion columna(hijos...) -> Layout {
    retornar col(hijos)
}

# Contenedor horizontal (flex fila)
funcion fila(hijos...) -> Layout {
    retornar row(hijos)
}

# Contenedor en Z (superposición)
funcion pila(hijos...) -> Layout {
    retornar zstack(hijos)
}

# Panel con separador redimensionable
# direccion: "horizontal" | "vertical"
funcion panel_dividido(hijo1, hijo2, direccion: Texto) -> Layout {
    retornar split(hijo1, hijo2, direccion)
}

# Contenedor con scroll
funcion desplazable(hijo) -> Layout {
    retornar scroll(hijo)
}

# Grid con posición
funcion grilla(hijos..., filas: Entero, columnas: Entero) -> Layout {
    retornar grid(hijos, filas, columnas)
}

# Caja con tamaño fijo
funcion caja_fija(hijo, ancho: Decimal, alto: Decimal) -> Layout {
    retornar sized(hijo, ancho, alto)
}

# ─── Widgets básicos ───

# Etiqueta de texto estático
funcion etiqueta(texto: Texto) -> Widget {
    retornar label(texto)
}

# Etiqueta dinámica (se actualiza automáticamente cuando cambia la variable)
funcion etiqueta_dinamica(variable: Texto) -> Widget {
    retornar varlabel(variable)
}

# Botón de texto con callback
funcion boton(texto: Texto, callback) -> Widget {
    retornar btn(texto, callback)
}

# Botón con callback sin argumentos extra
funcion boton_simple(texto: Texto, callback) -> Widget {
    retornar btn(texto, callback)
}

# Entrada de texto
funcion entrada_texto(variable: Texto) -> Widget {
    retornar input(variable)
}

# Entrada de texto multilínea
funcion area_texto(variable: Texto) -> Widget {
    retornar textarea(variable)
}

# ─── Widgets de datos ───

# Barra de progreso
funcion barra_progreso(variable: Texto) -> Widget {
    retornar progress(variable)
}

# Barra de progreso indeterminada (spinner de carga)
funcion cargando() -> Widget {
    retornar spinner()
}

# Deslizante (slider)
funcion deslizante(variable: Texto, minimo: Decimal, maximo: Decimal) -> Widget {
    retornar slider(variable, minimo, maximo)
}

# Casilla de verificación (checkbox)
funcion casilla(etiqueta: Texto, variable: Texto) -> Widget {
    retornar check(etiqueta, variable)
}

# ─── Widgets de presentación ───

# Texto enriquecido (Markdown simple)
funcion texto_enriquecido(texto: Texto) -> Widget {
    retornar prose(texto)
}

# Separador visual
funcion separador() -> Widget {
    retornar divider()
}

# Espaciador
funcion espacio(tamano: Decimal) -> Widget {
    retornar spacer(tamano)
}

# ─── Helpers internos (mapean a transpiler Xilem) ───

funcion text(s: Texto) -> Texto { retornar s }
funcion btn(s: Texto, cb) { retornar s }
funcion col(s) { retornar s }
funcion row(s) { retornar s }
funcion zstack(s) { retornar s }
funcion split(a, b, d: Texto) { retornar a }
funcion scroll(h) { retornar h }
funcion grid(h, f: Entero, c: Entero) { retornar h }
funcion sized(h, w: Decimal, hh: Decimal) { retornar h }
funcion label(s: Texto) -> Texto { retornar s }
funcion varlabel(v: Texto) -> Texto { retornar v }
funcion input(v: Texto) -> Texto { retornar v }
funcion textarea(v: Texto) -> Texto { retornar v }
funcion progress(v: Texto) -> Decimal { retornar 0.0 }
funcion spinner() -> Texto { retornar "" }
funcion slider(v: Texto, min: Decimal, max: Decimal) -> Decimal { retornar 0.0 }
funcion check(l: Texto, v: Texto) -> Texto { retornar v }
funcion prose(t: Texto) -> Texto { retornar t }
funcion divider() -> Texto { retornar "" }
funcion spacer(t: Decimal) -> Texto { retornar "" }

# ==========================================
# API DE TEMA MATERIAL YOU
# ==========================================
# Estas funciones exponen el sistema de tema Material Design 3
# con colores dinámicos (Monet), tipografía, formas y elevación.
# Uso: importar "gui" y llamar a estas funciones desde main().

# ─── Tema ───

# Crea un tema con un color semilla (formato hex #RRGGBB o nombre en español)
# Ejemplo: tema_material("#FF5722", columna(...))
funcion tema_material(color_semilla: Texto, hijo) { retornar hijo }

# ─── Colores del tema ───
# Aplican un color del esquema Material You al widget hijo.
# Cada función retorna el widget con el color aplicado.
# Colores primarios
funcion color_primario(hijo) { retornar hijo }
funcion color_sobre_primario(hijo) { retornar hijo }
funcion color_primario_contenedor(hijo) { retornar hijo }
funcion color_sobre_primario_contenedor(hijo) { retornar hijo }

# Colores secundarios
funcion color_secundario(hijo) { retornar hijo }
funcion color_sobre_secundario(hijo) { retornar hijo }
funcion color_secundario_contenedor(hijo) { retornar hijo }
funcion color_sobre_secundario_contenedor(hijo) { retornar hijo }

# Colores terciarios
funcion color_terciario(hijo) { retornar hijo }
funcion color_sobre_terciario(hijo) { retornar hijo }

# Colores de error
funcion color_error(hijo) { retornar hijo }
funcion color_sobre_error(hijo) { retornar hijo }

# Colores de superficie y fondo
funcion color_superficie(hijo) { retornar hijo }
funcion color_sobre_superficie(hijo) { retornar hijo }
funcion color_fondo(hijo) { retornar hijo }
funcion color_sobre_fondo(hijo) { retornar hijo }

# Color de perfil (bordes)
funcion color_perfil(hijo) { retornar hijo }

# ─── Tipografía (15 estilos Material You) ───
# Textos display (grandes, para títulos decorativos)
funcion texto_grande(t: Texto) -> Texto { retornar t }
funcion texto_mediano(t: Texto) -> Texto { retornar t }
funcion texto_pequeño(t: Texto) -> Texto { retornar t }

# Titulares (headlines)
funcion titular_grande(t: Texto) -> Texto { retornar t }
funcion titular_mediano(t: Texto) -> Texto { retornar t }
funcion titular_pequeño(t: Texto) -> Texto { retornar t }

# Encabezados (titles)
funcion encabezado_grande(t: Texto) -> Texto { retornar t }
funcion encabezado_mediano(t: Texto) -> Texto { retornar t }
funcion encabezado_pequeño(t: Texto) -> Texto { retornar t }

# Cuerpo de texto (body)
funcion cuerpo_grande(t: Texto) -> Texto { retornar t }
funcion cuerpo_mediano(t: Texto) -> Texto { retornar t }
funcion cuerpo_pequeño(t: Texto) -> Texto { retornar t }

# Etiquetas (labels)
funcion etiqueta_grande(t: Texto) -> Texto { retornar t }
funcion etiqueta_mediana(t: Texto) -> Texto { retornar t }
funcion etiqueta_pequeña(t: Texto) -> Texto { retornar t }

# ─── Formas (border-radius) ───
# Aplican un radio de borde al widget hijo
funcion esquinas_pequeñas(hijo) { retornar hijo }
funcion esquinas_medianas(hijo) { retornar hijo }
funcion esquinas_grandes(hijo) { retornar hijo }
funcion esquinas_completas(hijo) { retornar hijo }

# ─── Layout avanzado ───

# Añade relleno (padding) alrededor del hijo
# cantidad: espacio en píxeles (Decimal)
funcion relleno(hijo, cantidad: Decimal) { retornar hijo }

# Hace que el hijo se expanda para llenar el espacio disponible
funcion expansor(hijo) { retornar hijo }

# Centra al hijo en el contenedor
funcion centrado(hijo) { retornar hijo }

# Aplica una sombra (elevación) al hijo
# nivel: 0-5 (0 = sin sombra, 5 = máxima elevación)
funcion sombra(hijo, nivel: Entero) { retornar hijo }

# Layout responsivo: define 3 variantes según el tamaño de ventana
# chico: < 600dp, mediano: 600-840dp, grande: > 840dp
funcion adaptable(chico, mediano, grande) { retornar chico }

# ==========================================
# LAYOUT AVANZADO Y RESPONSIVE
# ==========================================

# Layout columna con gap y alineación
# hijos: tupla de widgets (hijo1, hijo2, ...)
# gap: espacio entre hijos en píxeles (Decimal)
# alinear: "start", "center", "end", "space_between", "space_around", "space_evenly"
funcion columna_con_gap(hijos, gap: Decimal, alinear: Texto) { retornar hijos }

# Layout fila con gap y alineación
funcion fila_con_gap(hijos, gap: Decimal, alinear: Texto) { retornar hijos }

# Flow layout con wrap automático
# hijos: tupla de widgets
# gap: espacio entre hijos en píxeles (Decimal)
funcion flujo(hijos, gap: Decimal) { retornar hijos }

# Caja con relación de aspecto fija
# hijo: widget a mostrar
# proporcion: relación ancho/alto (Decimal, ej: 1.777 para 16:9)
funcion caja_relativa(hijo, proporcion: Decimal) { retornar hijo }

# Flex layout configurable
# hijos: tupla de widgets
# axis: "vertical" | "horizontal"
# gap: espacio entre hijos
# wrap: verdadero/falso (si debe ajustar en múltiples líneas)
funcion flex_layout(hijos, axis: Texto, gap: Decimal, wrap: Booleano) { retornar hijos }

# Helpers internos para los nuevos layouts
funcion column_with_gap(hijos, gap: Decimal, alinear: Texto) { retornar hijos }
funcion row_with_gap(hijos, gap: Decimal, alinear: Texto) { retornar hijos }
funcion flow_layout(hijos, gap: Decimal) { retornar hijos }
funcion aspect_ratio(hijo, proporcion: Decimal) { retornar hijo }
funcion flex(hijos, axis: Texto, gap: Decimal, wrap: Booleano) { retornar hijos }

