# ==========================================
# FEEDBACK Y SUPERPOSICIONES
# ==========================================

# ─── Diálogos ───

# Diálogo de alerta simple
# titulo: Texto, mensaje: Texto
funcion dialogo_alerta(titulo: Texto, mensaje: Texto) -> Texto { retornar titulo }
funcion dialog_alert(titulo: Texto, mensaje: Texto) -> Texto { retornar titulo }

# Diálogo de confirmación con callbacks
# titulo: Texto, mensaje: Texto, cb_confirmar, cb_cancelar
funcion dialogo_confirmacion(titulo: Texto, mensaje: Texto, cb_confirmar, cb_cancelar) -> Texto { retornar titulo }
funcion dialog_confirm(titulo: Texto, mensaje: Texto, cb_confirm, cb_cancel) -> Texto { retornar titulo }

# Diálogo personalizado con hijo arbitrario
# titulo: Texto, hijo: widget
funcion dialogo_personalizado(titulo: Texto, hijo) -> Texto { retornar titulo }
funcion dialog_custom(titulo: Texto, hijo) -> Texto { retornar titulo }

# Diálogo completo (pantalla completa)
# titulo: Texto, hijo: widget
funcion dialogo_completo(titulo: Texto, hijo) -> Texto { retornar titulo }
funcion dialog_full(titulo: Texto, hijo) -> Texto { retornar titulo }

# ─── Bottom Sheets ───

# Hoja inferior estándar (sin overlay)
# hijo: widget, visible: Texto (nombre de variable bool)
