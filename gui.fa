# ==========================================
# ICONOS MATERIAL DESIGN
# ==========================================
# Sistema de iconos vectoriales Material Design con 100+ iconos.
# Los iconos se renderizan como emoji con tamaño y color.
# Cuando Xilem soporte SVG, se renderizarán los paths vectoriales reales.

# Icono Material genérico (elige automáticamente el emoji según el nombre)
# nombre: nombre del icono en inglés o español (ej: "home", "favorite", "settings")
# tamaño: tamaño en píxeles (Decimal, ej: 24, 32, 48)
# color: color en hex (#RRGGBB) o nombre de role del tema ("primary", "secondary", "error")
# estilo (opcional): "filled", "outlined", "rounded", "sharp", "twotone"
funcion icono_material(nombre: Texto, tamaño: Decimal, color: Texto) -> Texto { retornar nombre }
funcion icono_material(nombre: Texto, tamaño: Decimal, color: Texto, estilo: Texto) -> Texto { retornar nombre }
funcion material_icon(nombre: Texto, tamaño: Decimal, color: Texto) -> Texto { retornar nombre }
funcion material_icon(nombre: Texto, tamaño: Decimal, color: Texto, estilo: Texto) -> Texto { retornar nombre }

# Icono relleno (estilo filled)
funcion icono_relleno(nombre: Texto, tamaño: Decimal) -> Texto { retornar nombre }
funcion icon_filled(nombre: Texto, tamaño: Decimal) -> Texto { retornar nombre }

# Icono perfilado/contorno (estilo outlined)
funcion icono_perfilado(nombre: Texto, tamaño: Decimal) -> Texto { retornar nombre }
funcion icon_outlined(nombre: Texto, tamaño: Decimal) -> Texto { retornar nombre }

# Icono redondeado (estilo rounded)
funcion icono_redondo(nombre: Texto, tamaño: Decimal) -> Texto { retornar nombre }
funcion icon_rounded(nombre: Texto, tamaño: Decimal) -> Texto { retornar nombre }

# Icono agudo (estilo sharp)
funcion icono_agudo(nombre: Texto, tamaño: Decimal) -> Texto { retornar nombre }
funcion icon_sharp(nombre: Texto, tamaño: Decimal) -> Texto { retornar nombre }

# Icono de dos tonos (estilo twotone)
funcion icono_dos_tonos(nombre: Texto, tamaño: Decimal) -> Texto { retornar nombre }
funcion icon_twotone(nombre: Texto, tamaño: Decimal) -> Texto { retornar nombre }
